{
  "manifest_version": 3,
  "name": "ExcaliHub",
  "version": "1.1.0",
  "description": "Save Excalidraw drawings directly to a private GitHub repository.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
    "host_permissions": [
      "https://excalidraw.com/*",
      "https://api.github.com/*",
      "https://github.com/*",
      "https://openrouter.ai/*"
    ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://excalidraw.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "quick-save": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Quick save current Excalidraw drawing"
    }
  }
}
